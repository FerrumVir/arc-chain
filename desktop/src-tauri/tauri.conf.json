{
  "build": {
    "distDir": "../src/dist",
    "devPath": "http://localhost:3000"
  },
  "package": {
    "productName": "ARC Node",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "io.arcchain.node",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": ["dmg", "app", "deb", "appimage"],
      "shortDescription": "ARC Chain validator node",
      "longDescription": "Run an ARC Chain validator node with a single click. View real-time network stats, manage staking, and earn fees."
    },
    "allowlist": {
      "shell": {
        "open": true
      }
    },
    "windows": [
      {
        "title": "ARC Node",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:*"
    }
  }
}
